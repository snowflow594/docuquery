# Variables de entorno para el frontend (Vite)
# En desarrollo: copiar como .env.local (Vite lo carga automáticamente)
# En producción (Cloudflare Pages): configurar en Settings → Environment variables

# URL base del backend en Render — sin barra final, sin /api
# Ejemplo: https://docuquery-backend.onrender.com
# En desarrollo NO se necesita esta variable (el proxy de Vite maneja /api → localhost:8000)
VITE_API_URL=https://docuquery-backend.onrender.com
